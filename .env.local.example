# Copy to .env.local and fill with values from your Supabase project
# (Project Settings → API). Do not commit real keys.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Parts Canada (server-only). Use sandbox URL while developing.
PARTS_CANADA_API_URL=https://api.partscanada.com/api/v2
PARTS_CANADA_API_KEY=your_parts_canada_bearer_token

# Protects cron routes (Vercel Cron sends Authorization: Bearer …)
# - /api/cron/parts-canada-sync
# - /api/cron/wix-contacts-sync
CRON_SECRET=generate_a_long_random_string

# Wix — OTOMOTO Toronto Moto (Contacts + Payment Links REST)
# Create key at https://manage.wix.com/account/api-keys
# Permissions needed: Contacts (read/manage), Payment Links (manage)
WIX_API_KEY=your_wix_api_key
WIX_SITE_ID=50360639-7b1c-4bc8-ae1e-bd7cb472d611
# Optional — some account-level calls need it
# WIX_ACCOUNT_ID=your_wix_account_id
WIX_CURRENCY=CAD

# Inbound contact webhook: POST /api/wix/webhooks/contacts
# Authorization: Bearer <WIX_WEBHOOK_SECRET>
# Exact Automation payload: see wix/automation-webhook.md
WIX_WEBHOOK_SECRET=generate_a_long_random_string
