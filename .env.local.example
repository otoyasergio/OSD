# Square-first shop expansion (A–F)

# Public URL for customer magic links (production app URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Square (payments, invoices, terminals)
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Twilio (2-way SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=shop@torontomoto.com
EMAIL_FROM_NAME=Toronto Moto

# Wix (Bookings webhook + contact sync)
WIX_API_KEY=
WIX_SITE_ID=
WIX_WEBHOOK_SECRET=
WIX_DEFAULT_LOCATION_ID=

# Fitment CSV import (optional path for scripts/import-fitment.ts)
FITMENT_CSV_PATH=
