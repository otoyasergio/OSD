# Environment variables

# --- Core (required) ---
NEXT_PUBLIC_SUPABASE_URL=
# Recommended for browser and SSR clients (sb_publishable_...).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallback; remove after migrating every environment to a publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public URL for customer magic links (production app URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Observability (optional) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Square (payments, invoices) ---
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=

# --- Twilio (2-way SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Prefer Messaging Service SID (A2P campaign sender pool). If set, From is optional.
TWILIO_MESSAGING_SERVICE_SID=
# Fallback / optional when Messaging Service is not used
TWILIO_FROM_NUMBER=
# Twilio Video (company messenger voice/video calls)
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=shop@torontomoto.com
EMAIL_FROM_NAME=Toronto Moto

# --- Wix (Bookings webhook + Contacts CRM sync) ---
# API key needs Contacts (read/manage) + Bookings read for intake webhooks.
WIX_API_KEY=
WIX_SITE_ID=
# Optional — some account-level Contacts calls need it
# WIX_ACCOUNT_ID=
WIX_CURRENCY=CAD
WIX_WEBHOOK_SECRET=
WIX_DEFAULT_LOCATION_ID=

# --- Parts Canada ---
PARTS_CANADA_API_KEY=
PARTS_CANADA_API_URL=

# --- Cron (Vercel) — Bearer only, never query string ---
CRON_SECRET=

# --- Fitment CSV import (optional path for scripts/import-fitment.ts) ---
FITMENT_CSV_PATH=
